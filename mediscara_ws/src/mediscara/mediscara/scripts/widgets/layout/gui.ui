}
QTabWidget::tab-bar {
	alignment: center;
}

QTabWidget::pane {
	border: 1px solid black;
}

QTabBar::tab {
	border: 1px solid black;
	border-radius: 7px;
	height: 100px;
	width: 140px;
	margin: 6 px;
	margin-left: 6px;
 }
