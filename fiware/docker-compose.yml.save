
mongo:    image: mongo:4.4
    command: --nojournal
orion:
    image: fiware/orion
    links:
      - mongo
    ports:
      - "1026:1026"
    command: -dbhost mongo

crate:
    image: crate:1.0.5
    hostname: crate-db
    ports:
      - "4200:4200"
      - "4300:4300"
    command:
      -Ccluster.name=democluster -Chttp.cors.enabled=true
      -Chttp.cors.allow-origin="*"

quantum-leap:
    image: smartsdk/quantumleap
    hostname: quantum-leap
    ports:
        - "8668:8668"
    depends_on:
        - crate-db
    environment:
        - CRATE_HOST=crate-db

grafana: 
    image: grafana/grafana
    depends_on:
      - crate-db
    ports:
      - "3003:3000"
    environment:
      - GF_INSTALL_PLUGINS=crate-datasource,grafana-clock-panel,grafana-worldmap-panel
